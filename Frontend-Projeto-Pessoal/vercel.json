{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api-gateway-al-tacad-o-production.up.railway.app/api/:path*" },
    { "source": "/cadastro/:path*", "destination": "https://api-gateway-al-tacad-o-production.up.railway.app/cadastro/:path*" },
    { "source": "/cadastro", "destination": "https://api-gateway-al-tacad-o-production.up.railway.app/cadastro" },
    { "source": "/fornecedor/:path*", "destination": "https://api-gateway-al-tacad-o-production.up.railway.app/fornecedor/:path*" },
    { "source": "/fornecedor", "destination": "https://api-gateway-al-tacad-o-production.up.railway.app/fornecedor" },
    { "source": "/((?!api|cadastro|fornecedor|assets|favicon).*)", "destination": "/index.html" }
  ]
}
